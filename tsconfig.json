{
    "compilerOptions": {
        "moduleResolution": "node16",
        "module": "node16",
        "target": "es2022",
        "strict": true,
        "noImplicitAny": true,
        "sourceMap": true,
        "declaration": true,
        "rootDir": "./src",
        "outDir": "dist/",
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "importHelpers": true,
        "lib": [
            "es2022"
        ]
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "typings/global",
        "typings/global.d.ts",
        "src/**/*.spec.ts"
    ]
}