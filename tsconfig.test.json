{
    "compilerOptions": {
        "rootDir": "./",
        "module": "node16",
        "moduleResolution": "node16",
        "target": "es2022",
        "strict": true,
        "noImplicitAny": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "importHelpers": true,
        "lib": ["es2022"],
        "types": ["node"],
        "esModuleInterop": true
    },
    "ts-node": {
        "transpileOnly": true
    },
    "include": ["src/**/*"]
}